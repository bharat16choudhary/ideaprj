<%- include('../partials/header') %>

<script>
    // Refresh page every 10 seconds to get new updates
    setTimeout(function() {
        location.reload();
    }, 10000);
</script>

<div class="dashboard-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #EAEAEA; padding-bottom: 20px; margin-bottom: 30px;">
    <h2 class="dashboard-title" style="margin: 0;"><%= user.name %>'s Dashboard</h2>
    <a href="/user/report" class="btn-gradient" style="width: auto; border-radius: 30px; padding: 12px 25px; box-shadow: 0 4px 15px rgba(255, 59, 59, 0.3);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Report Accident
    </a>
</div>

<h3 class="section-title">Active Requests</h3>

<% if (activeRequests.length === 0) { %>
    <p style="margin-bottom: 40px;">You have no active emergency requests.</p>
<% } else { %>
    <div class="requests-grid">
        <% activeRequests.forEach(request => { %>
            <a href="/user/request/<%= request._id %>" class="card status-<%= request.status %>">
                <div class="card-header">
                    <div class="card-title"><%= request.patientName %></div>
                    <span class="badge <%= request.status %>"><%= request.status %></span>
                </div>
                <div class="card-body">
                    <p><strong>Date:</strong> <%= new Date(request.createdAt).toLocaleString() %></p>
                    <p><strong>Injured:</strong> <%= request.injuredCount %></p>
                </div>
                <div class="card-actions">
                    <span class="btn btn-outline" style="font-size: 14px; padding: 8px 15px;">View Details</span>
                </div>
            </a>
        <% }) %>
    </div>
<% } %>

<h3 class="section-title">History (Completed / Rejected)</h3>

<% if (historyRequests.length === 0) { %>
    <p>No historical requests found.</p>
<% } else { %>
    <div class="requests-grid">
        <% historyRequests.forEach(request => { %>
            <a href="/user/request/<%= request._id %>" class="card status-<%= request.status %>" style="opacity: 0.8;">
                <div class="card-header">
                    <div class="card-title"><%= request.patientName %></div>
                    <span class="badge <%= request.status %>"><%= request.status %></span>
                </div>
                <div class="card-body">
                    <p><strong>Date:</strong> <%= new Date(request.createdAt).toLocaleString() %></p>
                    <p><strong>Injured:</strong> <%= request.injuredCount %></p>
                    <% if (request.status === 'completed' && request.hospitalAdmitted) { %>
                        <p><strong>Admitted to:</strong> <span style="color: var(--primary-green); font-weight: 600;"><%= request.hospitalAdmitted %></span></p>
                    <% } %>
                </div>
                <div class="card-actions">
                    <span class="btn btn-outline" style="font-size: 14px; padding: 8px 15px;">View Details</span>
                </div>
            </a>
        <% }) %>
    </div>
<% } %>

<%- include('../partials/footer') %>
