<%- include('../partials/header') %>
<script>
    document.body.classList.add('provider-dark-theme');
</script>

<div class="dashboard-header" style="border-bottom: none; margin-bottom: 25px; padding-bottom: 0;">
    <h2 class="dashboard-title" style="font-weight: 800; font-size: 32px;">
        <%= emergencyRequest.status === 'completed' ? 'Emergency Summary' : 'Emergency Tracking' %>
    </h2>
    <a href="/ambulance/dashboard" class="btn-pill-outline">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Back to Dashboard
    </a>
</div>

<div class="tracking-grid <%= emergencyRequest.status === 'completed' ? 'summary-mode' : 'active-mode' %>">
    <!-- Left Column: Map and Navigation -->
    <div class="map-column">
        <div id="map" 
             data-lat="<%= emergencyRequest.location.lat %>" 
             data-lng="<%= emergencyRequest.location.lng %>"
             data-status="<%= emergencyRequest.status %>"
             data-id="<%= emergencyRequest._id %>"
             data-admitted="<%= emergencyRequest.hospitalAdmitted || '' %>">
        </div>

        <% if (emergencyRequest.status !== 'completed') { %>
            <div class="tracking-actions" style="display: flex; flex-direction: column; gap: 15px; margin-top: 20px;">
                <div id="reachedMsg" style="display: <%= emergencyRequest.status === 'reached' ? 'block' : 'none' %>; background: rgba(34, 197, 94, 0.1); border: 1px solid #22c55e; color: #22c55e; padding: 12px; border-radius: 12px; text-align: center; font-weight: 600; margin-bottom: 5px;">
                    ✅ You have reached the patient location
                </div>

                <button id="navBtn" class="btn-nav-blue" style="text-align: center; width: 100%; border: none; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 10px;">
                    🚑 Navigate to Patient
                </button>
                
                <button type="button" id="openCompleteModal" class="btn-accept-glow" style="width: 100%; display: flex; justify-content: center; align-items: center; gap: 10px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    Mark as Completed
                </button>
            </div>
        <% } %>
    </div>

    <!-- Right Column: Patient Details & Summary -->
    <div class="details-column">
        <% if (emergencyRequest.status !== 'completed') { %>
            <h3 class="section-title" style="margin-top: 0;">Live Status</h3>
            <div class="live-status-container" style="border: 1px solid #334155; margin-bottom: 25px;">
                <div class="status-step completed">
                    <div class="status-icon">✓</div>
                    <div class="status-text">Accepted</div>
                </div>
                <div class="status-step <%= (emergencyRequest.status === 'accepted') ? 'active' : 'completed' %>" id="step-onway">
                    <div class="status-line <%= (emergencyRequest.status !== 'accepted') ? 'completed' : '' %>" style="left: -50%; width: 100%;"></div>
                    <div class="status-icon" id="icon-onway"><%= (emergencyRequest.status === 'accepted') ? '🚑' : '✓' %></div>
                    <div class="status-text">On the way</div>
                </div>
                <div class="status-step <%= (emergencyRequest.status === 'reached') ? 'active' : '' %>" id="step-reached">
                    <div class="status-line" id="line-reached" style="left: -50%; width: 100%;"></div>
                    <div class="status-icon">📍</div>
                    <div class="status-text">Reached</div>
                </div>
            </div>
        <% } %>

        <div class="card status-<%= emergencyRequest.status %>" style="margin-bottom: 25px; border: 1px solid #334155; box-shadow: 0 4px 20px rgba(0,0,0,0.2);">
            <div class="card-header" style="border-bottom: 1px solid #334155; padding-bottom: 12px; margin-bottom: 15px;">
                <div class="card-title" style="font-size: 20px;">Patient Details</div>
                <span id="statusBadge" class="badge <%= emergencyRequest.status %>"><%= emergencyRequest.status %></span>
            </div>
            <div class="card-body">
                <% if (emergencyRequest.status !== 'completed') { %>
                    <div id="distanceContainer" style="background: #0f172a; padding: 12px; border-radius: 10px; margin-bottom: 15px; border: 1px solid #1e293b;">
                        <span style="color: #94a3b8; font-size: 13px; display: block; margin-bottom: 4px;">Current Distance</span>
                        <span id="distanceValue" style="color: #3b82f6; font-size: 18px; font-weight: 800;">Calculating...</span>
                    </div>
                <% } %>
                <p style="font-size: 16px; margin-bottom: 12px;"><strong>Name:</strong> <%= emergencyRequest.patientName %></p>
                <p style="font-size: 16px; margin-bottom: 12px;"><strong>Phone:</strong> <%= emergencyRequest.phone %></p>
                <p style="font-size: 16px; margin-bottom: 12px;"><strong>Injured:</strong> <%= emergencyRequest.injuredCount %></p>
            </div>
        </div>

        <% if (emergencyRequest.status === 'completed') { %>
            <div class="card" style="border: 1px solid #22c55e; background: rgba(34, 197, 94, 0.05); box-shadow: 0 4px 20px rgba(34, 197, 94, 0.1);">
                <div class="card-header" style="border-bottom: 1px solid rgba(34, 197, 94, 0.2); padding-bottom: 12px; margin-bottom: 15px;">
                    <div class="card-title" style="color: #22c55e; font-size: 20px; display: flex; align-items: center; gap: 8px;">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                        Hospital Used
                    </div>
                </div>
                <div class="card-body" style="text-align: center; padding: 10px 0;">
                    <h4 style="color: white; font-size: 22px; font-weight: 800; margin-bottom: 10px;">🏥 <%= emergencyRequest.hospitalAdmitted || 'Local Hospital' %></h4>
                    <p style="color: #cbd5e1; font-size: 14px;">Emergency successfully completed at this facility.</p>
                </div>
            </div>
        <% } else { %>
            <h3 class="section-title">Nearest Hospitals</h3>
            <div class="hospital-list">
                <% nearestHospitals.forEach(function(hospital) { %>
                    <div class="hospital-card" style="border: 1px solid #334155; background: #1e293b;">
                        <div>
                            <div class="hospital-name" style="font-size: 16px;"><%= hospital.name %></div>
                        </div>
                        <a href="https://www.google.com/maps/dir/?api=1&destination=<%= hospital.lat %>,<%= hospital.lng %>" target="_blank" class="btn-nav-green" style="padding: 10px 18px; border-radius: 12px;">
                            🏥 Navigate
                        </a>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<!-- Completion Modal -->
<div id="completeModal" class="completion-modal">
    <div class="modal-content">
        <h3>Mission Accomplished</h3>
        <p style="color: #cbd5e1; margin-bottom: 15px; font-size: 14px;">Which hospital was the patient admitted to?</p>
        
        <form action="/ambulance/complete/<%= emergencyRequest._id %>" method="POST" id="completeForm">
            <select name="hospitalName" required>
                <option value="" disabled selected>Select Hospital</option>
                <% nearestHospitals.forEach(function(hospital) { %>
                    <option value="<%= hospital.name %>"><%= hospital.name %></option>
                <% }) %>
                <option value="Other">Other / Local Clinic</option>
            </select>
            
            <div class="modal-actions">
                <button type="button" id="closeModal" class="btn-cancel">Cancel</button>
                <button type="submit" class="btn-confirm">Complete</button>
            </div>
        </form>
    </div>
</div>

<!-- Alert Modal for Navigation -->
<div id="navAlertModal" class="completion-modal">
    <div class="modal-content" style="border-top: 5px solid #22c55e;">
        <div style="font-size: 40px; margin-bottom: 15px;">📍</div>
        <h3 style="margin-bottom: 10px;">Already Reached</h3>
        <p style="color: #cbd5e1; margin-bottom: 25px;">You have already reached the patient location.</p>
        <button type="button" id="closeNavAlert" class="btn-confirm" style="width: 100%;">OK</button>
    </div>
</div>

<!-- Pass hospital data safely via a hidden script block -->
<script id="hospitalsJSON" type="application/json"><%= JSON.stringify(nearestHospitals) %></script>

<style>
    .tracking-grid { display: grid; gap: 25px; }
    .tracking-grid.active-mode { grid-template-columns: 2fr 1fr; }
    .tracking-grid.summary-mode { grid-template-columns: 1.5fr 1fr; }
    @media (max-width: 992px) { .tracking-grid.active-mode, .tracking-grid.summary-mode { grid-template-columns: 1fr; } }
    #navBtn.reached { opacity: 0.7; }
</style>

<%- include('../partials/footer') %>

<script>
    // Runs after footer.ejs has loaded Leaflet JS
    window.addEventListener('load', function() {
        var mapEl = document.getElementById('map');
        if (!mapEl) return;
        if (typeof L === 'undefined') { console.error('Leaflet failed to load'); return; }

        var pLat = parseFloat(mapEl.getAttribute('data-lat'));
        var pLng = parseFloat(mapEl.getAttribute('data-lng'));
        var requestId = mapEl.getAttribute('data-id');
        var currentStatus = mapEl.getAttribute('data-status');
        var admittedHospitalName = mapEl.getAttribute('data-admitted');

        if (isNaN(pLat) || isNaN(pLng)) return;

        // Initialize map
        var map = L.map('map').setView([pLat, pLng], 14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '\u00A9 OpenStreetMap contributors'
        }).addTo(map);

        // Icons
        var patientIcon = L.divIcon({
            className: 'custom-div-icon',
            html: '<div style="background-color:#E63946;width:15px;height:15px;border-radius:50%;border:3px solid white;box-shadow:0 0 5px rgba(0,0,0,0.5);"></div>',
            iconSize: [20, 20], iconAnchor: [10, 10]
        });
        var ambulanceIcon = L.divIcon({
            className: 'custom-div-icon',
            html: '<div style="background-color:#3b82f6;width:18px;height:18px;border-radius:50%;border:3px solid white;box-shadow:0 0 10px rgba(59,130,246,0.8);display:flex;align-items:center;justify-content:center;font-size:10px;">\uD83D\uDE91</div>',
            iconSize: [24, 24], iconAnchor: [12, 12]
        });
        var hospitalIcon = L.divIcon({
            className: 'custom-div-icon',
            html: '<div style="background-color:#2A9D8F;width:15px;height:15px;border-radius:50%;border:3px solid white;box-shadow:0 0 5px rgba(0,0,0,0.5);"></div>',
            iconSize: [20, 20], iconAnchor: [10, 10]
        });

        // Patient marker
        var patientMarker = L.marker([pLat, pLng], { icon: patientIcon }).addTo(map)
            .bindPopup('<b>Patient Location</b>').openPopup();
        var providerMarker = null;

        // Hospital markers from safe JSON block
        var hospitalsEl = document.getElementById('hospitalsJSON');
        if (hospitalsEl) {
            try {
                var hospitals = JSON.parse(hospitalsEl.textContent);
                hospitals.forEach(function(hospital) {
                    if (currentStatus === 'completed') {
                        if (hospital.name === admittedHospitalName) {
                            L.marker([hospital.lat, hospital.lng], { icon: hospitalIcon }).addTo(map)
                                .bindPopup('<b>Admitted: ' + hospital.name + '</b>').openPopup();
                        }
                    } else {
                        L.marker([hospital.lat, hospital.lng], { icon: hospitalIcon }).addTo(map)
                            .bindPopup('<b>' + hospital.name + '</b>');
                    }
                });
            } catch (e) {
                console.error('Error parsing hospital data:', e);
            }
        }

        // Haversine distance formula (returns metres)
        function getDistance(lat1, lon1, lat2, lon2) {
            var R = 6371e3;
            var rad = Math.PI / 180;
            var dLat = (lat2 - lat1) * rad;
            var dLon = (lon2 - lon1) * rad;
            var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                    Math.cos(lat1 * rad) * Math.cos(lat2 * rad) *
                    Math.sin(dLon / 2) * Math.sin(dLon / 2);
            return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        }

        // Auto-mark reached via AJAX
        var reachRequestSent = false;
        function markAsReached() {
            if (reachRequestSent) return;
            reachRequestSent = true;
            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/ambulance/reached/' + requestId, true);
            xhr.setRequestHeader('Content-Type', 'application/json');
            xhr.onload = function() {
                if (xhr.status === 200) {
                    try {
                        var data = JSON.parse(xhr.responseText);
                        if (data.success) {
                            currentStatus = 'reached';
                            updateUIReached();
                        } else {
                            reachRequestSent = false;
                        }
                    } catch (e) {
                        console.error('Error parsing reached response:', e);
                        reachRequestSent = false;
                    }
                } else {
                    reachRequestSent = false;
                }
            };
            xhr.onerror = function() {
                console.error('Network error marking reached');
                reachRequestSent = false;
            };
            xhr.send();
        }

        // Update UI to show "reached" state
        function updateUIReached() {
            var distEl = document.getElementById('distanceValue');
            if (distEl) { distEl.innerText = 'Nearby (Arrived)'; distEl.style.color = '#22c55e'; }

            var navBtnEl = document.getElementById('navBtn');
            if (navBtnEl) { navBtnEl.classList.add('reached'); navBtnEl.innerText = '\uD83D\uDCCD Arrived at Location'; }

            var reachedMsg = document.getElementById('reachedMsg');
            if (reachedMsg) reachedMsg.style.display = 'block';

            var badge = document.getElementById('statusBadge');
            if (badge) { badge.innerText = 'reached'; badge.className = 'badge reached'; }

            var stepOnWay = document.getElementById('step-onway');
            if (stepOnWay) { stepOnWay.className = 'status-step completed'; }
            var iconOnWay = document.getElementById('icon-onway');
            if (iconOnWay) iconOnWay.innerText = '\u2713';
            if (stepOnWay) {
                var lineOnWay = stepOnWay.querySelector('.status-line');
                if (lineOnWay) lineOnWay.classList.add('completed');
            }

            var stepReached = document.getElementById('step-reached');
            if (stepReached) stepReached.className = 'status-step active';
        }

        // Real-time tracking UI update
        function updateTrackingUI(lat, lng) {
            var distance = getDistance(lat, lng, pLat, pLng);
            var distEl = document.getElementById('distanceValue');
            if (!distEl) return;

            if (distance <= 50 && currentStatus === 'accepted') {
                markAsReached();
            }

            if (currentStatus === 'reached' || distance <= 50) {
                distEl.innerText = 'Nearby (Arrived)';
                distEl.style.color = '#22c55e';
            } else {
                distEl.innerText = (distance / 1000).toFixed(2) + ' km away';
                distEl.style.color = '#3b82f6';
            }

            if (providerMarker) {
                providerMarker.setLatLng([lat, lng]);
            } else {
                providerMarker = L.marker([lat, lng], { icon: ambulanceIcon }).addTo(map)
                    .bindPopup('<b>Your Location</b>');
                map.fitBounds(L.featureGroup([patientMarker, providerMarker]).getBounds(), { padding: [50, 50] });
            }
        }

        // Start geolocation
        if (currentStatus !== 'completed' && navigator.geolocation) {
            navigator.geolocation.watchPosition(
                function(pos) { updateTrackingUI(pos.coords.latitude, pos.coords.longitude); },
                function(err) { console.error('Geolocation error:', err); },
                { enableHighAccuracy: true }
            );
        }

        // Apply reached UI if already reached from server
        if (currentStatus === 'reached') { updateUIReached(); }

        // Navigation Button
        var navBtn = document.getElementById('navBtn');
        var navAlertModal = document.getElementById('navAlertModal');
        var closeNavAlert = document.getElementById('closeNavAlert');

        if (navBtn) {
            navBtn.addEventListener('click', function() {
                if (currentStatus === 'reached') {
                    if (navAlertModal) navAlertModal.classList.add('show');
                } else {
                    window.open('https://www.google.com/maps/dir/?api=1&destination=' + pLat + ',' + pLng, '_blank');
                }
            });
        }
        if (closeNavAlert) {
            closeNavAlert.addEventListener('click', function() {
                if (navAlertModal) navAlertModal.classList.remove('show');
            });
        }

        // Completion Modal
        var modal = document.getElementById('completeModal');
        var openBtn = document.getElementById('openCompleteModal');
        var closeBtn = document.getElementById('closeModal');

        if (modal && openBtn) {
            openBtn.addEventListener('click', function() { modal.classList.add('show'); });
        }
        if (modal && closeBtn) {
            closeBtn.addEventListener('click', function() { modal.classList.remove('show'); });
        }

        // Close modals on backdrop click
        document.addEventListener('click', function(event) {
            if (modal && event.target === modal) modal.classList.remove('show');
            if (navAlertModal && event.target === navAlertModal) navAlertModal.classList.remove('show');
        });
    });
</script>
