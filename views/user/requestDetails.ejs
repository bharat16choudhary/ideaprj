<%- include('../partials/header') %>

<script>
    // Refresh page every 10 seconds to get status updates
    setTimeout(function() {
        location.reload();
    }, 10000);
</script>

<div class="dashboard-header" style="border-bottom: none; margin-bottom: 20px; padding-bottom: 0;">
    <h2 class="dashboard-title" style="font-weight: 800; font-size: 32px;">Request Details</h2>
    <a href="/user/dashboard" class="btn-pill-outline">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Back to Dashboard
    </a>
</div>

<div class="card status-<%= emergencyRequest.status %>" style="max-width: 800px; margin: 0 auto 30px;">
    <div class="card-header">
        <div class="card-title"><%= emergencyRequest.patientName %></div>
        <span class="badge <%= emergencyRequest.status %>" style="font-size: 16px; padding: 8px 15px;"><%= emergencyRequest.status %></span>
    </div>
    
    <% if (emergencyRequest.status === 'accepted') { %>
        <div style="background-color: #e3f2fd; color: #1565c0; padding: 15px; border-radius: 8px; margin-bottom: 20px; font-weight: bold; text-align: center;">
            🚑 Ambulance is on the way!
        </div>
    <% } else if (emergencyRequest.status === 'reached') { %>
        <div style="background-color: #f0fdf4; color: #15803d; padding: 15px; border-radius: 8px; margin-bottom: 20px; font-weight: bold; text-align: center; border: 1px solid #22c55e;">
            ✅ Ambulance has arrived at your location!
        </div>
    <% } %>

    <div class="card-body" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
        <p><strong>Phone:</strong> <%= emergencyRequest.phone %></p>
        <p><strong>Injured Count:</strong> <%= emergencyRequest.injuredCount %></p>
        <p><strong>Date/Time:</strong> <%= new Date(emergencyRequest.createdAt).toLocaleString() %></p>
        <p><strong>Status:</strong> <%= emergencyRequest.status.charAt(0).toUpperCase() + emergencyRequest.status.slice(1) %></p>
    </div>

    <div id="map" data-lat="<%= emergencyRequest.location.lat %>" data-lng="<%= emergencyRequest.location.lng %>"></div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const mapEl = document.getElementById('map');
        const lat = parseFloat(mapEl.getAttribute('data-lat'));
        const lng = parseFloat(mapEl.getAttribute('data-lng'));
        
        const map = L.map('map').setView([lat, lng], 15);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);
        
        const marker = L.marker([lat, lng]).addTo(map);
        marker.bindPopup("<b>Accident Location</b><br>Help is requested here.").openPopup();
    });
</script>

<%- include('../partials/footer') %>
