<%- include('partials/header') %>

<div class="auth-container">
    <h2>Sign Up as <%= role === 'user' ? 'User' : 'Ambulance' %></h2>
    
    <% if (error) { %>
        <div class="error-msg"><%= error %></div>
    <% } %>

    <form action="/signup" method="POST">
        <input type="hidden" name="role" value="<%= role %>">
        
        <div class="form-group">
            <label for="name">Full Name / Agency Name</label>
            <input type="text" id="name" name="name" required>
        </div>
        
        <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required>
        </div>
        
        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required>
        </div>
        
        <button type="submit" class="btn btn-success" style="width: 100%;">Sign Up</button>
    </form>
    
    <div class="auth-links">
        <p>Already have an account? <a href="/login?role=<%= role %>">Login here</a></p>
    </div>
</div>

<%- include('partials/footer') %>
